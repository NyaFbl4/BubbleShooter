<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="CurrentBubble" style="flex-grow: 1; width: 100px; height: 150px; min-height: 150px; max-height: 150px; min-width: 100px; max-width: 100px; background-image: resource(&apos;UI/match3_purple/table&apos;); top: 0; left: 0; margin-top: 5px; margin-right: 5px; margin-bottom: 5px; margin-left: 5px;">
        <ui:VisualElement name="BubbleImg" style="flex-grow: 1; background-image: resource(&apos;Bubbles/BlueCan&apos;); width: 90px; height: 90px; min-height: 90px; max-height: 90px; top: 8px; left: 4px;" />
